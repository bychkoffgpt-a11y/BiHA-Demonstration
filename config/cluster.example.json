{
  "poll_interval_sec": 2,
  "nodes": [
    {
      "name": "pg-master",
      "dsn": "postgresql://postgres:postgres@10.0.0.11:5432/postgres",
      "role_hint": "master",
      "control_via_ssh": true,
      "ssh_host": "10.0.0.11",
      "ssh_user": "postgres",
      "service_name": "postgrespro"
    },
    {
      "name": "pg-slave",
      "dsn": "postgresql://postgres:postgres@10.0.0.12:5432/postgres",
      "role_hint": "slave",
      "control_via_ssh": true,
      "ssh_host": "10.0.0.12",
      "ssh_user": "postgres",
      "service_name": "postgrespro"
    }
  ]
}
